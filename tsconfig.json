{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["astro/client"],
    "allowJs": true,
    "checkJs": false
  },
  "include": [".astro/types.d.ts", "src/**/*", "*.ts", "*.mts"],
  "exclude": ["dist", "node_modules", "scripts/**", "**/*.mjs"]
}
