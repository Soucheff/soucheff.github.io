---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '@/lib/i18n';
import { getLocalizedMeta, entryUrl, ui } from '@/lib/i18n';
import TagBadge from './TagBadge.astro';

interface Props {
  entry: CollectionEntry<'demos'>;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const meta = getLocalizedMeta(entry, locale);
const href = entryUrl('demos', entry.slug, locale);
const t = ui[locale];
---

<article class="card">
  <header class="mb-2">
    <h3 class="m-0 text-lg font-bold">
      <a href={href} class="no-underline" style="color: var(--color-text);">{meta.title}</a>
    </h3>
  </header>
  <p class="mb-3 text-sm" style="color: var(--color-text-muted);">{meta.description}</p>

  {entry.data.tech.length > 0 && (
    <div class="mb-2 flex flex-wrap gap-1.5">
      {entry.data.tech.map((t) => (
        <span class="badge badge-accent">{t}</span>
      ))}
    </div>
  )}

  {entry.data.tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {entry.data.tags.map((tag) => (
        <TagBadge tag={tag} locale={locale} />
      ))}
    </div>
  )}

  <div class="mt-3 flex flex-wrap gap-3 text-sm">
    <a href={href}>{t.readMore} →</a>
    {entry.data.liveUrl && (
      <a href={entry.data.liveUrl} target="_blank" rel="noopener noreferrer">{t.liveDemo} ↗</a>
    )}
    {entry.data.repoUrl && (
      <a href={entry.data.repoUrl} target="_blank" rel="noopener noreferrer">{t.sourceCode} ↗</a>
    )}
  </div>
</article>
