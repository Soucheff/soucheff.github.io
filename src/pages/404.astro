---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ui, type Locale } from '@/lib/i18n';

const locale: Locale = 'pt';
const t = ui[locale];
---

<BaseLayout
  locale={locale}
  title="404"
  description={t.pageNotFound}
  indexable={false}
>
  <div class="container-narrow py-12 text-center">
    <p class="mb-2 text-6xl font-bold" style="color: var(--color-primary);">404</p>
    <h1 class="mb-3 text-2xl font-bold" style="color: var(--color-text);">{t.pageNotFound}</h1>
    <p class="mb-2" style="color: var(--color-text-muted);">{t.pageNotFoundDescription}</p>
    <p class="mb-6" style="color: var(--color-text-muted);">Page not found / The page you are looking for does not exist.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a class="btn btn-primary" href="/">{t.homeLink}</a>
      <a class="btn btn-accent" href="/en/">{ui.en.homeLink}</a>
    </div>
  </div>
</BaseLayout>
