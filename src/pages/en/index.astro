---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import DemoCard from '@/components/DemoCard.astro';
import { ui, collectionPath, type Locale } from '@/lib/i18n';
import { getArticlesForLocale, getDemosForLocale } from '@/lib/content';

const locale: Locale = 'en';
const t = ui[locale];

const articles = (await getArticlesForLocale(locale)).slice(0, 4);
const demos = (await getDemosForLocale(locale)).slice(0, 3);
---

<BaseLayout
  locale={locale}
  title={t.siteName}
  description={t.tagline}
  translations={{ pt: '/', en: '/en/' }}
>
  <section class="mb-12 rounded-lg border border-[color:var(--color-border)] p-8" style="background-color: var(--color-surface);">
    <p class="mb-2 text-sm font-semibold uppercase tracking-wider" style="color: var(--color-primary);">
      Pedro Soucheff
    </p>
    <h1 class="mb-3 text-4xl font-bold sm:text-5xl" style="color: var(--color-text);">
      {t.tagline}
    </h1>
    <p class="mb-6 text-lg" style="color: var(--color-text-muted);">
      Technical articles and practical demonstrations on Microsoft Entra ID, Zero Trust,
      IAM, Microsoft Defender, and Azure security.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href={collectionPath('articles', locale)} class="btn btn-primary">{t.viewAllArticles}</a>
      <a href={collectionPath('demos', locale)} class="btn btn-accent">{t.viewAllDemos}</a>
    </div>
  </section>

  <section class="mb-12">
    <header class="mb-4 flex items-baseline justify-between">
      <h2 class="text-2xl font-bold" style="color: var(--color-text);">{t.latestArticles}</h2>
      <a href={collectionPath('articles', locale)} class="text-sm">{t.viewAllArticles} →</a>
    </header>
    {articles.length === 0 ? (
      <p style="color: var(--color-text-muted);">{t.noContent}</p>
    ) : (
      <div class="grid gap-4 md:grid-cols-2">
        {articles.map((entry) => (
          <ArticleCard entry={entry} locale={locale} />
        ))}
      </div>
    )}
  </section>

  <section>
    <header class="mb-4 flex items-baseline justify-between">
      <h2 class="text-2xl font-bold" style="color: var(--color-text);">{t.featuredDemos}</h2>
      <a href={collectionPath('demos', locale)} class="text-sm">{t.viewAllDemos} →</a>
    </header>
    {demos.length === 0 ? (
      <p style="color: var(--color-text-muted);">{t.noContent}</p>
    ) : (
      <div class="grid gap-4 md:grid-cols-2">
        {demos.map((entry) => (
          <DemoCard entry={entry} locale={locale} />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
